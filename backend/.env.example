# ─────────────────────────────────────────────────────────────
#  HRMS Lite — Backend Environment Configuration
#  Copy this to .env and fill in your values
# ─────────────────────────────────────────────────────────────

# MySQL — update USER, PASSWORD, and DATABASE to match your setup
DATABASE_URL=mysql+pymysql://root:your_password@localhost:3306/hrms_db

# App mode
APP_ENV=development

# Allowed frontend origins (comma-separated, no spaces)
ALLOWED_ORIGINS=http://localhost:5173,http://localhost:3000
